<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบจำลองรอบเดือนและการตกไข่ (ม.2)</title>
  
  <!-- เรียกใช้ Tailwind CSS เพื่อความสวยงาม -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- เรียกใช้ React -->
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  
  <!-- เรียกใช้ Babel เพื่อแปลงโค้ด JSX ให้เบราว์เซอร์อ่านออก -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
</head>
<body class="bg-slate-50 font-sans pb-12">
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect } = React;

    // --- ส่วนของไอคอน (ดัดแปลงเป็น SVG เพื่อให้รวมในไฟล์เดียวได้) ---
    const CalendarIcon = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>;
    const Info = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>;
    const ArrowRight = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>;
    const CheckCircle2 = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="m9 12 2 2 4-4"></path></svg>;
    const RotateCcw = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>;
    const AlertCircle = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>;
    const Sparkles = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"></path></svg>;
    const ChevronRight = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m9 18 6-6-6-6"></path></svg>;
    const ChevronLeft = ({ className }) => <svg xmlns="http://www.w3.org/2000/svg" className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m15 18-6-6 6-6"></path></svg>;

    // --- ข้อมูลคำถามแบบทดสอบ ---
    const quizQuestions = [
      {
        question: "หากนางสาวเอเริ่มมีประจำเดือนวันแรกในวันที่ 1 มกราคม และเธอมีรอบเดือนปกติ 28 วัน วันแรกของประจำเดือนรอบถัดไปควรจะเป็นวันที่เท่าใด",
        options: ["วันที่ 27 มกราคม", "วันที่ 28 มกราคม", "วันที่ 29 มกราคม", "วันที่ 14 มกราคม"],
        correctAnswer: "วันที่ 29 มกราคม",
        explanation: "นับจากวันที่ 1 ไปอีก 28 วัน (1 + 28 = 29) ประจำเดือนรอบใหม่จะมาในวันที่ 29 มกราคม"
      },
      {
        question: "การนับระยะเวลาของ 'รอบเดือน' (Menstrual Cycle) ที่ถูกต้องควรเริ่มนับอย่างไร",
        options: [
          "นับจากวันสุดท้ายที่มีประจำเดือนจนถึงวันแรกที่มีประจำเดือนรอบถัดไป",
          "นับจากวันแรกที่มีประจำเดือนจนถึงวันแรกที่มีประจำเดือนรอบถัดไป",
          "นับจากวันไข่ตกจนถึงวันแรกที่มีประจำเดือน",
          "นับเฉพาะวันที่มีเลือดประจำเดือนไหลเท่านั้น"
        ],
        correctAnswer: "นับจากวันแรกที่มีประจำเดือนจนถึงวันแรกที่มีประจำเดือนรอบถัดไป",
        explanation: "รอบเดือน 1 รอบ เริ่มนับจาก 'วันแรก' ที่มีประจำเดือน ไปจนถึง 'วันก่อน' ที่ประจำเดือนรอบใหม่จะมา"
      },
      {
        question: "หากนางสาวบีมีรอบเดือน 28 วัน และประจำเดือนวันแรกของรอบนี้คือวันที่ 10 กุมภาพันธ์ วันที่คาดว่า 'ไข่จะตก' คือวันที่เท่าใด",
        options: ["วันที่ 24 กุมภาพันธ์", "วันที่ 23 กุมภาพันธ์", "วันที่ 14 กุมภาพันธ์", "วันที่ 17 กุมภาพันธ์"],
        correctAnswer: "วันที่ 24 กุมภาพันธ์",
        explanation: "วิธีคิด: ประจำเดือนรอบหน้าคือ 10 ก.พ. + 28 วัน = 10 มี.ค. (ปีปกติ ก.พ.มี 28 วัน) วันไข่ตกคือนับถอยหลัง 14 วันจากรอบหน้า (10 มี.ค. - 14 วัน = 24 ก.พ.)"
      },
      {
        question: "นางสาวซีมีรอบเดือนสม่ำเสมอ 30 วัน หากประจำเดือนวันแรกคือวันที่ 1 มีนาคม การตกไข่ของเธอควรเกิดขึ้นในวันที่เท่าใดของเดือนมีนาคม",
        options: ["วันที่ 14 มีนาคม", "วันที่ 15 มีนาคม", "วันที่ 16 มีนาคม", "วันที่ 17 มีนาคม"],
        correctAnswer: "วันที่ 17 มีนาคม",
        explanation: "วิธีคิดที่ง่ายที่สุดคือ 'ความยาวรอบเดือน - 14' (30 - 14 = 16) แปลว่าไข่ตกในวันที่ 16 ของรอบเดือน ถ้านับวันที่ 1 มีนาคมเป็นวันที่ 1 วันที่ 16 ของรอบเดือนก็คือวันที่ 17 มีนาคม (1 + 16 = 17)"
      },
      {
        question: "ถ้านางสาวดีมีรอบเดือนสม่ำเสมอ 32 วัน ประจำเดือนรอบล่าสุดมาวันที่ 1 เมษายน วันที่คาดว่า 'ไข่จะตก' คือวันที่เท่าใด",
        options: ["วันที่ 14 เมษายน", "วันที่ 16 เมษายน", "วันที่ 18 เมษายน", "วันที่ 20 เมษายน"],
        correctAnswer: "วันที่ 19 เมษายน",
        explanation: "ความยาวรอบเดือน 32 วัน วันไข่ตกคือ 32 - 14 = 18 (ไข่ตกวันที่ 18 ของรอบเดือน) ถ้านับ 1 เมษาเป็นวันที่ 1 วันที่ 18 ของรอบเดือนคือวันที่ 19 เมษายน (1 + 18 = 19)"
      },
      {
        question: "ช่วงเวลาใดในรอบเดือนที่มีโอกาสตั้งครรภ์ได้สูงที่สุด (Fertile Window)",
        options: [
          "ช่วงที่มีประจำเดือนพอดี",
          "ช่วง 7 วันก่อนมีประจำเดือน",
          "ช่วง 1 - 3 วัน ก่อนและหลังการตกไข่",
          "ช่วง 1 สัปดาห์หลังประจำเดือนหมดทันที"
        ],
        correctAnswer: "ช่วง 1 - 3 วัน ก่อนและหลังการตกไข่",
        explanation: "อสุจิสามารถมีชีวิตรอในมดลูกได้ 2-3 วัน และไข่ที่ตกมาจะมีชีวิตอยู่ได้ 12-24 ชั่วโมง ช่วงนี้จึงมีโอกาสปฏิสนธิสูงสุด"
      },
      {
        question: "เหตุใดการนับ 'หน้า 7 หลัง 7' จึงไม่สามารถใช้คุมกำเนิดได้อย่างปลอดภัย 100%",
        options: [
          "เพราะอสุจิแข็งแรงเกินไป",
          "เพราะไข่อาจตกก่อนหรือหลังกำหนดได้หากรอบเดือนไม่สม่ำเสมอ",
          "เพราะมดลูกสามารถสร้างไข่ได้หลายใบพร้อมกัน",
          "เพราะเป็นวิธีที่ใช้ได้เฉพาะกับผู้ใหญ่เท่านั้น"
        ],
        correctAnswer: "เพราะไข่อาจตกก่อนหรือหลังกำหนดได้หากรอบเดือนไม่สม่ำเสมอ",
        explanation: "หากมีความเครียด หรือฮอร์โมนเปลี่ยน วันไข่ตกอาจเลื่อนได้ ทำให้การนับวันผิดพลาดและเสี่ยงต่อการตั้งครรภ์"
      }
    ];

    // --- ฟังก์ชันช่วยเหลือเกี่ยวกับวันที่ ---
    const addDays = (date, days) => {
      const result = new Date(date);
      result.setDate(result.getDate() + days);
      return result;
    };

    const isSameDay = (date1, date2) => {
      if (!date1 || !date2) return false;
      return date1.getDate() === date2.getDate() &&
             date1.getMonth() === date2.getMonth() &&
             date1.getFullYear() === date2.getFullYear();
    };

    const monthNamesThai = [
      "มกราคม", "กุมภาพันธ์", "มีนาคม", "เมษายน", "พฤษภาคม", "มิถุนายน",
      "กรกฎาคม", "สิงหาคม", "กันยายน", "ตุลาคม", "พฤศจิกายน", "ธันวาคม"
    ];

    // --- คอมโพเนนต์ปฏิทินย่อย ---
    const CalendarMonth = ({ year, month, selectedDate, ovulationDate, nextPeriodDate, onDateClick }) => {
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      
      const days = [];
      for (let i = 0; i < firstDay; i++) {
        days.push(null); 
      }
      for (let i = 1; i <= daysInMonth; i++) {
        days.push(new Date(year, month, i));
      }

      return (
        <div className="bg-white p-4 rounded-xl shadow-sm border border-pink-100">
          <h3 className="text-center font-bold text-gray-700 mb-4 text-lg">
            {monthNamesThai[month]} {year + 543}
          </h3>
          <div className="grid grid-cols-7 gap-1 text-center mb-2">
            {['อา', 'จ', 'อ', 'พ', 'พฤ', 'ศ', 'ส'].map(d => (
              <div key={d} className="text-xs font-semibold text-gray-400">{d}</div>
            ))}
          </div>
          <div className="grid grid-cols-7 gap-1">
            {days.map((date, index) => {
              if (!date) return <div key={`empty-${index}`} className="h-10 w-10"></div>;
              
              const isSelected = isSameDay(date, selectedDate);
              const isOvulation = isSameDay(date, ovulationDate);
              const isNextPeriod = isSameDay(date, nextPeriodDate);
              
              let btnClass = "h-10 w-10 flex items-center justify-center rounded-full text-sm font-medium transition-all duration-200 ";
              
              if (isSelected) {
                btnClass += "bg-pink-500 text-white shadow-md shadow-pink-200 scale-110 z-10";
              } else if (isOvulation) {
                btnClass += "bg-yellow-400 text-white shadow-md shadow-yellow-200 scale-110 z-10 animate-pulse";
              } else if (isNextPeriod) {
                btnClass += "bg-rose-400 text-white shadow-md shadow-rose-200 scale-110 z-10";
              } else {
                btnClass += "text-gray-600 hover:bg-pink-50 cursor-pointer";
              }

              return (
                <div key={index} className="flex justify-center items-center">
                  <button 
                    onClick={() => onDateClick(date)}
                    className={btnClass}
                    title={isSelected ? "วันแรกของประจำเดือน" : isOvulation ? "วันตกไข่" : isNextPeriod ? "ประจำเดือนรอบถัดไป" : ""}
                  >
                    {date.getDate()}
                  </button>
                </div>
              );
            })}
          </div>
        </div>
      );
    };

    // --- คอมโพเนนต์หน้าจำลองปฏิทิน ---
    const CycleSimulator = ({ onFinishSimulation }) => {
      const [cycleLength, setCycleLength] = useState(28);
      const [selectedDate, setSelectedDate] = useState(null);
      const [ovulationDate, setOvulationDate] = useState(null);
      const [nextPeriodDate, setNextPeriodDate] = useState(null);
      const [currentDisplayDate, setCurrentDisplayDate] = useState(new Date());

      useEffect(() => {
        if (selectedDate) {
          const nextPeriod = addDays(selectedDate, cycleLength);
          // กฎเหล็ก: ตกไข่คือ 14 วันก่อนรอบถัดไป
          const ovulation = addDays(nextPeriod, -14);
          
          setNextPeriodDate(nextPeriod);
          setOvulationDate(ovulation);
        } else {
          setNextPeriodDate(null);
          setOvulationDate(null);
        }
      }, [selectedDate, cycleLength]);

      const handleNextMonth = () => {
        setCurrentDisplayDate(new Date(currentDisplayDate.getFullYear(), currentDisplayDate.getMonth() + 1, 1));
      };

      const handlePrevMonth = () => {
        setCurrentDisplayDate(new Date(currentDisplayDate.getFullYear(), currentDisplayDate.getMonth() - 1, 1));
      };

      const cycleOptions = [21, 28, 30, 32];

      return (
        <div className="max-w-4xl mx-auto p-4 md:p-6 space-y-6">
          <div className="bg-gradient-to-r from-pink-500 to-rose-400 rounded-2xl p-6 text-white shadow-lg">
            <h1 className="text-2xl md:text-3xl font-bold mb-2 flex items-center gap-2">
              <CalendarIcon className="w-8 h-8" />
              ระบบจำลองรอบเดือนและการตกไข่
            </h1>
            <p className="text-pink-50">มาทดลองนับวันตกไข่กันเถอะ! ลองจำลองสถานการณ์ของตัวเองดูนะ</p>
          </div>

          <div className="grid md:grid-cols-3 gap-6">
            {/* ซ้าย: ตัวควบคุม */}
            <div className="md:col-span-1 space-y-6">
              <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                <h3 className="font-bold text-gray-800 mb-4 flex items-center gap-2">
                  <span className="bg-pink-100 text-pink-600 w-6 h-6 rounded-full flex items-center justify-center text-sm">1</span>
                  เลือกระยะเวลารอบเดือน
                </h3>
                <div className="grid grid-cols-2 gap-2">
                  {cycleOptions.map(days => (
                    <button
                      key={days}
                      onClick={() => setCycleLength(days)}
                      className={`py-2 px-3 rounded-lg font-medium transition-colors ${
                        cycleLength === days 
                        ? 'bg-pink-500 text-white shadow-md' 
                        : 'bg-gray-50 text-gray-600 hover:bg-pink-50'
                      }`}
                    >
                      {days} วัน
                    </button>
                  ))}
                </div>
                <p className="text-xs text-gray-500 mt-3 flex gap-1 items-start">
                  <Info className="w-4 h-4 flex-shrink-0" />
                  รอบเดือนปกติของผู้หญิงจะอยู่ที่ 21-35 วัน (เฉลี่ย 28 วัน)
                </p>
              </div>

              <div className="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                <h3 className="font-bold text-gray-800 mb-4 flex items-center gap-2">
                  <span className="bg-pink-100 text-pink-600 w-6 h-6 rounded-full flex items-center justify-center text-sm">2</span>
                  ผลการจำลอง
                </h3>
                
                {!selectedDate ? (
                  <div className="text-center py-4 text-gray-400">
                    <Sparkles className="w-8 h-8 mx-auto mb-2 opacity-50" />
                    <p className="text-sm">จิ้มเลือก "วันแรกที่มีประจำเดือน" บนปฏิทินเพื่อดูผลลัพธ์</p>
                  </div>
                ) : (
                  <div className="space-y-4">
                    <div className="flex items-center gap-3 bg-pink-50 p-3 rounded-lg border border-pink-100">
                      <div className="w-4 h-4 rounded-full bg-pink-500 flex-shrink-0"></div>
                      <div>
                        <div className="text-xs text-gray-500">วันแรกของประจำเดือน</div>
                        <div className="font-bold text-pink-700">
                          {selectedDate.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric'})}
                        </div>
                      </div>
                    </div>

                    <div className="flex items-center gap-3 bg-yellow-50 p-3 rounded-lg border border-yellow-100">
                      <div className="w-4 h-4 rounded-full bg-yellow-400 flex-shrink-0"></div>
                      <div>
                        <div className="text-xs text-gray-500">วันตกไข่ (คาดการณ์)</div>
                        <div className="font-bold text-yellow-700">
                          {ovulationDate?.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric'})}
                        </div>
                        <div className="text-[10px] text-yellow-600 leading-tight mt-1">
                          (นับถอยหลัง 14 วันจากประจำเดือนรอบหน้า)
                        </div>
                      </div>
                    </div>

                    <div className="flex items-center gap-3 bg-rose-50 p-3 rounded-lg border border-rose-100">
                      <div className="w-4 h-4 rounded-full bg-rose-400 flex-shrink-0"></div>
                      <div>
                        <div className="text-xs text-gray-500">ประจำเดือนรอบถัดไป</div>
                        <div className="font-bold text-rose-700">
                          {nextPeriodDate?.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric'})}
                        </div>
                        <div className="text-[10px] text-rose-600 leading-tight mt-1">
                          (นับไปข้างหน้า {cycleLength} วัน)
                        </div>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            </div>

            {/* ขวา: ปฏิทิน */}
            <div className="md:col-span-2">
              <div className="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <div className="flex justify-between items-center mb-4 px-2">
                  <h3 className="font-bold text-gray-800 flex items-center gap-2">
                     <span className="bg-pink-100 text-pink-600 w-6 h-6 rounded-full flex items-center justify-center text-sm">3</span>
                     ปฏิทิน
                  </h3>
                  <div className="flex gap-2">
                    <button onClick={handlePrevMonth} className="p-1 hover:bg-gray-100 rounded-full transition-colors"><ChevronLeft className="w-5 h-5 text-gray-600" /></button>
                    <button onClick={handleNextMonth} className="p-1 hover:bg-gray-100 rounded-full transition-colors"><ChevronRight className="w-5 h-5 text-gray-600" /></button>
                  </div>
                </div>
                
                <div className="grid sm:grid-cols-2 gap-4">
                  <CalendarMonth 
                    year={currentDisplayDate.getFullYear()} 
                    month={currentDisplayDate.getMonth()} 
                    selectedDate={selectedDate}
                    ovulationDate={ovulationDate}
                    nextPeriodDate={nextPeriodDate}
                    onDateClick={setSelectedDate}
                  />
                  <CalendarMonth 
                    year={currentDisplayDate.getMonth() === 11 ? currentDisplayDate.getFullYear() + 1 : currentDisplayDate.getFullYear()} 
                    month={currentDisplayDate.getMonth() === 11 ? 0 : currentDisplayDate.getMonth() + 1} 
                    selectedDate={selectedDate}
                    ovulationDate={ovulationDate}
                    nextPeriodDate={nextPeriodDate}
                    onDateClick={setSelectedDate}
                  />
                </div>
              </div>

              <div className="mt-8 flex justify-end">
                <button
                  onClick={onFinishSimulation}
                  className="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-xl font-bold text-lg flex items-center gap-2 shadow-lg shadow-indigo-200 transition-transform transform hover:scale-105 active:scale-95"
                >
                  เข้าใจแล้ว! ไปทำแบบทดสอบกันเถอะ
                  <ArrowRight className="w-5 h-5" />
                </button>
              </div>
            </div>
          </div>
        </div>
      );
    };

    // --- คอมโพเนนต์หน้าแบบทดสอบ ---
    const Quiz = ({ onBackToSimulator }) => {
      const [currentQuestion, setCurrentQuestion] = useState(0);
      const [score, setScore] = useState(0);
      const [showScore, setShowScore] = useState(false);
      const [selectedAnswer, setSelectedAnswer] = useState("");
      const [isAnswered, setIsAnswered] = useState(false);
      const [answersLog, setAnswersLog] = useState([]);

      const handleAnswerOptionClick = (option) => {
        if (isAnswered) return;
        
        setSelectedAnswer(option);
        setIsAnswered(true);

        const isCorrect = option === quizQuestions[currentQuestion].correctAnswer;
        if (isCorrect) {
          setScore(score + 1);
        }

        setAnswersLog([...answersLog, {
          question: quizQuestions[currentQuestion].question,
          userAnswer: option,
          isCorrect: isCorrect,
          explanation: quizQuestions[currentQuestion].explanation
        }]);
      };

      const handleNextQuestion = () => {
        const nextQuestion = currentQuestion + 1;
        if (nextQuestion < quizQuestions.length) {
          setCurrentQuestion(nextQuestion);
          setSelectedAnswer("");
          setIsAnswered(false);
        } else {
          setShowScore(true);
        }
      };

      const resetQuiz = () => {
        setCurrentQuestion(0);
        setScore(0);
        setShowScore(false);
        setSelectedAnswer("");
        setIsAnswered(false);
        setAnswersLog([]);
      };

      if (showScore) {
        return (
          <div className="max-w-3xl mx-auto p-4 md:p-6 space-y-6">
            <div className="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
              <div className="bg-gradient-to-r from-pink-500 to-rose-400 p-8 text-center text-white">
                <h2 className="text-3xl font-bold mb-2">สรุปคะแนนของคุณ</h2>
                <div className="text-6xl font-black mb-2">{score} / {quizQuestions.length}</div>
                <p className="text-pink-100 text-lg">
                  {score === quizQuestions.length ? "สุดยอด! คุณคือมาสเตอร์เรื่องรอบเดือน" : 
                   score >= quizQuestions.length / 2 ? "เก่งมาก! เข้าใจกลไกของร่างกายได้ดี" : 
                   "พยายามได้ดี! ลองกลับไปทบทวนในปฏิทินจำลองอีกครั้งนะ"}
                </p>
              </div>

              <div className="p-6 md:p-8 space-y-6">
                <h3 className="text-xl font-bold text-gray-800 border-b pb-2">เฉลยคำตอบ</h3>
                {answersLog.map((log, index) => (
                  <div key={index} className={`p-4 rounded-xl border ${log.isCorrect ? 'bg-green-50 border-green-200' : 'bg-red-50 border-red-200'}`}>
                    <p className="font-medium text-gray-800 mb-2">{index + 1}. {log.question}</p>
                    <div className="flex items-start gap-2 mb-2">
                      {log.isCorrect ? (
                        <CheckCircle2 className="w-5 h-5 text-green-500 mt-0.5 shrink-0" />
                      ) : (
                        <AlertCircle className="w-5 h-5 text-red-500 mt-0.5 shrink-0" />
                      )}
                      <p className={log.isCorrect ? "text-green-700" : "text-red-700"}>
                        คุณตอบ: <span className="font-semibold">{log.userAnswer}</span>
                      </p>
                    </div>
                    <div className="bg-white p-3 rounded-lg text-sm text-gray-600 mt-3 shadow-sm">
                      <span className="font-semibold text-indigo-600">คำอธิบาย: </span> 
                      {log.explanation}
                    </div>
                  </div>
                ))}

                <div className="flex flex-col sm:flex-row gap-4 pt-6">
                  <button
                    onClick={resetQuiz}
                    className="flex-1 bg-pink-100 hover:bg-pink-200 text-pink-700 font-bold py-3 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors"
                  >
                    <RotateCcw className="w-5 h-5" /> ทำแบบทดสอบอีกครั้ง
                  </button>
                  <button
                    onClick={onBackToSimulator}
                    className="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors"
                  >
                    <CalendarIcon className="w-5 h-5" /> กลับไปเล่นปฏิทิน
                  </button>
                </div>
              </div>
            </div>
          </div>
        );
      }

      return (
        <div className="max-w-2xl mx-auto p-4 md:p-6">
          <div className="mb-6 flex justify-between items-center">
            <button 
              onClick={onBackToSimulator}
              className="text-gray-500 hover:text-indigo-600 flex items-center gap-1 text-sm font-medium transition-colors"
            >
              <ChevronLeft className="w-4 h-4" /> กลับหน้าปฏิทิน
            </button>
            <span className="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-sm font-bold">
              ข้อที่ {currentQuestion + 1} / {quizQuestions.length}
            </span>
          </div>

          <div className="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
            <div className="p-6 md:p-8">
              <h2 className="text-xl md:text-2xl font-bold text-gray-800 leading-relaxed mb-6">
                {quizQuestions[currentQuestion].question}
              </h2>

              <div className="space-y-3">
                {quizQuestions[currentQuestion].options.map((option, index) => {
                  let buttonStyle = "bg-gray-50 border-gray-200 text-gray-700 hover:bg-pink-50 hover:border-pink-300";
                  
                  if (isAnswered) {
                    if (option === quizQuestions[currentQuestion].correctAnswer) {
                      buttonStyle = "bg-green-100 border-green-500 text-green-800 ring-2 ring-green-500 ring-opacity-50";
                    } else if (option === selectedAnswer) {
                      buttonStyle = "bg-red-100 border-red-500 text-red-800 ring-2 ring-red-500 ring-opacity-50";
                    } else {
                      buttonStyle = "bg-gray-50 border-gray-200 text-gray-400 opacity-50";
                    }
                  }

                  return (
                    <button
                      key={index}
                      onClick={() => handleAnswerOptionClick(option)}
                      disabled={isAnswered}
                      className={`w-full text-left p-4 rounded-xl border-2 transition-all duration-200 font-medium ${buttonStyle}`}
                    >
                      <div className="flex items-center justify-between">
                        <span>{option}</span>
                        {isAnswered && option === quizQuestions[currentQuestion].correctAnswer && (
                          <CheckCircle2 className="w-6 h-6 text-green-600" />
                        )}
                      </div>
                    </button>
                  );
                })}
              </div>

              {isAnswered && (
                <div className="mt-8">
                  <div className="bg-indigo-50 border border-indigo-100 p-4 rounded-xl mb-6">
                    <h4 className="font-bold text-indigo-800 mb-1 flex items-center gap-2">
                      <Info className="w-5 h-5" /> คำอธิบาย
                    </h4>
                    <p className="text-indigo-900/80 text-sm leading-relaxed">
                      {quizQuestions[currentQuestion].explanation}
                    </p>
                  </div>
                  <button
                    onClick={handleNextQuestion}
                    className="w-full bg-pink-500 hover:bg-pink-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-pink-200 transition-all active:scale-95 flex items-center justify-center gap-2"
                  >
                    {currentQuestion + 1 === quizQuestions.length ? "ดูสรุปคะแนน" : "ข้อต่อไป"}
                    <ArrowRight className="w-5 h-5" />
                  </button>
                </div>
              )}
            </div>
          </div>
        </div>
      );
    };

    // --- คอมโพเนนต์หลัก ---
    function App() {
      const [view, setView] = useState('simulator');

      return (
        <div>
          <header className="bg-white border-b border-gray-200 sticky top-0 z-50">
            <div className="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
              <div className="flex items-center gap-2">
                <div className="w-8 h-8 rounded-full bg-gradient-to-br from-pink-500 to-rose-400 flex items-center justify-center text-white font-bold">
                  วิทย์
                </div>
                <span className="font-bold text-gray-800 text-lg hidden sm:block">วิทยาศาสตร์ ม.2</span>
              </div>
              <div className="flex bg-gray-100 p-1 rounded-lg">
                <button 
                  onClick={() => setView('simulator')}
                  className={`px-4 py-1.5 text-sm font-bold rounded-md transition-all ${view === 'simulator' ? 'bg-white text-pink-600 shadow-sm' : 'text-gray-500 hover:text-gray-700'}`}
                >
                  1. ปฏิทินจำลอง
                </button>
                <button 
                  onClick={() => setView('quiz')}
                  className={`px-4 py-1.5 text-sm font-bold rounded-md transition-all ${view === 'quiz' ? 'bg-white text-indigo-600 shadow-sm' : 'text-gray-500 hover:text-gray-700'}`}
                >
                  2. แบบทดสอบ
                </button>
              </div>
            </div>
          </header>

          <main className="pt-6">
            {view === 'simulator' ? (
              <CycleSimulator onFinishSimulation={() => setView('quiz')} />
            ) : (
              <Quiz onBackToSimulator={() => setView('simulator')} />
            )}
          </main>
        </div>
      );
    }

    // คำสั่งสร้างหน้าเว็บ
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
